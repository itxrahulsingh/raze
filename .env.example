# =============================================================================
# RAZE Enterprise AI OS - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before starting services.
# NEVER commit your .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
# The public IP address or hostname of this server
SERVER_IP=127.0.0.1

# Environment: development | staging | production
ENVIRONMENT=production

# Debug mode: false in production
DEBUG=false

# -----------------------------------------------------------------------------
# JWT / AUTH
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=raze
POSTGRES_USER=raze
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=change_me_generate_with_openssl_rand_hex_16

# Full DSN (constructed from above; used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://raze:change_me_generate_with_openssl_rand_hex_16@postgres:5432/raze

# Connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=change_me_generate_with_openssl_rand_hex_16
REDIS_DB=0
REDIS_URL=redis://:change_me_generate_with_openssl_rand_hex_16@redis:6379/0

# Cache TTL defaults (seconds)
CACHE_DEFAULT_TTL=3600
CACHE_SESSION_TTL=86400

# -----------------------------------------------------------------------------
# MINIO (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=raze_admin
# Generate with: openssl rand -hex 16
MINIO_ROOT_PASSWORD=change_me_generate_with_openssl_rand_hex_16
MINIO_USE_SSL=false

# Bucket names
MINIO_BUCKET_DOCUMENTS=raze-documents
MINIO_BUCKET_MEDIA=raze-media
MINIO_BUCKET_EXPORTS=raze-exports

# External URL for pre-signed URLs (replace with your server IP)
MINIO_EXTERNAL_URL=http://127.0.0.1:9000

# Storage backend: "minio" (S3) or "local" (filesystem)
STORAGE_BACKEND=minio

# Local storage path (used when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=/app/storage

# -----------------------------------------------------------------------------
# QDRANT (Vector Database)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# Generate with: openssl rand -hex 24
QDRANT_API_KEY=change_me_generate_with_openssl_rand_hex_24

# Collection names
QDRANT_COLLECTION_KNOWLEDGE=raze_knowledge
QDRANT_COLLECTION_MEMORY=raze_memory
QDRANT_VECTOR_SIZE=3072

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

# -----------------------------------------------------------------------------
# ANTHROPIC (Optional)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_DEFAULT_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# BACKEND (FastAPI)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
BACKEND_RELOAD=false

# CORS — set to your server IP; comma-separated for multiple origins
# Must match pydantic-settings field name: allowed_origins
ALLOWED_ORIGINS=http://127.0.0.1,http://127.0.0.1:3000,http://127.0.0.1:80

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# File upload
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# FRONTEND (Next.js)
# -----------------------------------------------------------------------------
# Must start with NEXT_PUBLIC_ to be accessible in browser
NEXT_PUBLIC_API_URL=http://127.0.0.1/api
NEXT_PUBLIC_WS_URL=ws://127.0.0.1/ws
NEXT_PUBLIC_APP_NAME=RAZE Enterprise AI OS
NEXT_PUBLIC_APP_VERSION=1.0.0

# Internal URL used by Next.js SSR (server-to-server)
INTERNAL_API_URL=http://backend:8000

# -----------------------------------------------------------------------------
# EMAIL (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=RAZE Platform
SMTP_TLS=true
SMTP_SSL=false

# -----------------------------------------------------------------------------
# CELERY (Background Tasks)
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:change_me_generate_with_openssl_rand_hex_16@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change_me_generate_with_openssl_rand_hex_16@redis:6379/2
CELERY_TASK_ALWAYS_EAGER=false
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Secret key for session signing (separate from JWT)
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# Allowed hosts (comma-separated)
ALLOWED_HOSTS=127.0.0.1,localhost

# CSRF
CSRF_SECRET=change_me_generate_with_openssl_rand_hex_32

# Password hashing rounds (higher = slower = more secure)
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# MONITORING (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=

# Prometheus metrics endpoint enabled
METRICS_ENABLED=true
METRICS_PORT=9090
